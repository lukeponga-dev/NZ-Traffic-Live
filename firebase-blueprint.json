{
  "entities": {
    "Incident": {
      "title": "Incident",
      "description": "A traffic incident or road alert.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the incident" },
        "type": { "type": "string", "description": "Type of incident (e.g., Crash, Roadworks)" },
        "severity": { "type": "string", "enum": ["Minor", "Moderate", "Severe"], "description": "Severity of the incident" },
        "description": { "type": "string", "description": "Detailed description" },
        "lat": { "type": "number", "description": "Latitude" },
        "lng": { "type": "number", "description": "Longitude" },
        "startTime": { "type": "string", "format": "date-time", "description": "When the incident started" },
        "updatedTime": { "type": "string", "format": "date-time", "description": "When the incident was last updated" }
      },
      "required": ["id", "type", "severity", "description", "lat", "lng", "startTime", "updatedTime"]
    },
    "UserReport": {
      "title": "UserReport",
      "description": "A report submitted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the report" },
        "userId": { "type": "string", "description": "ID of the user who submitted the report" },
        "type": { "type": "string", "description": "Type of incident reported" },
        "description": { "type": "string", "description": "User's description" },
        "lat": { "type": "number", "description": "Latitude" },
        "lng": { "type": "number", "description": "Longitude" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the report was submitted" },
        "status": { "type": "string", "enum": ["pending", "verified", "resolved"], "description": "Status of the report" }
      },
      "required": ["id", "userId", "type", "description", "lat", "lng", "timestamp", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's photo URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" }
      },
      "required": ["uid", "displayName", "email", "role"]
    }
  },
  "firestore": {
    "/incidents/{incidentId}": {
      "schema": "Incident",
      "description": "Collection of traffic incidents."
    },
    "/userReports/{reportId}": {
      "schema": "UserReport",
      "description": "Collection of user-submitted reports."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
